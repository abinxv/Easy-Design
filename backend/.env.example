PORT=5000
# Replace the placeholders below with the Atlas database user you create in MongoDB Atlas.
# If your password contains special characters like @ ? # or /, URL-encode it first.
MONGO_URI=mongodb+srv://<atlas-username>:<atlas-password>@cluster0.xxxxx.mongodb.net/easydesign?retryWrites=true&w=majority&appName=Cluster0

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=30d
CLIENT_URL=http://localhost:5173,http://localhost:8080
BCRYPT_SALT_ROUNDS=12

OPEN_ROUTER=your-openrouter-api-key
